# Ria Pet Store Environment Configuration
# Copy this file to .env and modify for your environment

# Application
APP_NAME="Ria Pet Store Management System"
APP_ENV=development
APP_URL="http://localhost/petstore"
APP_DEBUG=true

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=pet_store
DB_PORT=3306
DB_CHARSET=utf8mb4

# File Uploads
UPLOAD_MAX_SIZE=2097152
UPLOAD_ALLOWED_TYPES="image/jpeg,image/png,image/gif"
UPLOAD_PATH="../assets/uploads/"

# Security
SESSION_NAME="petstore_session"
SESSION_LIFETIME=7200
HASH_COST=10

# API
API_TIMEOUT=30
API_VERSION="v1"