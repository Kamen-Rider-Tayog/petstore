DirectoryIndex index.php index.html

Options -Indexes

RewriteEngine On
RewriteBase /Ria-Pet-Store/

# Pass through real files and directories (css, js, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── Home ────────────────────────────────────────────────────
RewriteRule ^$                        public/pages/index.php [QSA,L]

# ── Shop ────────────────────────────────────────────────────
RewriteRule ^products$                public/shop/products.php [QSA,L]
RewriteRule ^product_details$         public/shop/product_details.php [QSA,L]
RewriteRule ^categories$              public/shop/categories.php [QSA,L]
RewriteRule ^category_products$       public/shop/category_products.php [QSA,L]
RewriteRule ^featured$                public/shop/featured.php [QSA,L]
RewriteRule ^new_arrivals$            public/shop/new_arrivals.php [QSA,L]
RewriteRule ^on_sale$                 public/shop/on_sale.php [QSA,L]
RewriteRule ^search$                  public/shop/search.php [QSA,L]
RewriteRule ^search_results$          public/shop/search_results.php [QSA,L]
RewriteRule ^advanced_search$         public/shop/advanced_search.php [QSA,L]
RewriteRule ^recently_viewed$         public/shop/recently_viewed.php [QSA,L]
RewriteRule ^low_stock$               public/shop/low_stock.php [QSA,L]
RewriteRule ^services$                public/shop/services.php [QSA,L]
RewriteRule ^service_details$         public/shop/service_details.php [QSA,L]
RewriteRule ^supplier_products$       public/shop/supplier_products.php [QSA,L]

# ── Pets ────────────────────────────────────────────────────
RewriteRule ^pets$                    public/pets/pets.php [QSA,L]
RewriteRule ^pet_details$             public/pets/pet_details.php [QSA,L]
RewriteRule ^dogs$                    public/pets/dogs.php [QSA,L]
RewriteRule ^search_pets$             public/pets/search_pets.php [QSA,L]

# ── Cart ────────────────────────────────────────────────────
RewriteRule ^cart$                    public/cart/cart.php [QSA,L]
RewriteRule ^checkout$                public/cart/checkout.php [QSA,L]
RewriteRule ^place_order$             public/cart/place_order.php [QSA,L]
RewriteRule ^order_confirmation$      public/cart/order_confirmation.php [QSA,L]
RewriteRule ^cancel_order$            public/cart/cancel_order.php [QSA,L]

# ── Orders ──────────────────────────────────────────────────
RewriteRule ^order_history$           public/orders/order_history.php [QSA,L]
RewriteRule ^order_details$           public/orders/order_details.php [QSA,L]
RewriteRule ^customer_order$          public/orders/customer_order.php [QSA,L]

# ── Appointments ────────────────────────────────────────────
RewriteRule ^book_appointment$        public/appointments/book_appointment.php [QSA,L]
RewriteRule ^appointments$            public/appointments/appointments.php [QSA,L]
RewriteRule ^my_appointments$         public/appointments/my_appointments.php [QSA,L]
RewriteRule ^cancel_appointment$      public/appointments/cancel_appointment.php [QSA,L]
RewriteRule ^reschedule_appointment$  public/appointments/reschedule_appointment.php [QSA,L]

# ── Auth ────────────────────────────────────────────────────
RewriteRule ^login$                   public/auth/login.php [QSA,L]
RewriteRule ^logout$                  public/auth/logout.php [QSA,L]
RewriteRule ^register$                public/auth/register.php [QSA,L]
RewriteRule ^login_process$           public/auth/login_process.php [QSA,L]
RewriteRule ^register_process$        public/auth/register_process.php [QSA,L]

# ── User ────────────────────────────────────────────────────
RewriteRule ^user_profile$            public/user/user_profile.php [QSA,L]
RewriteRule ^edit_profile$            public/user/edit_profile.php [QSA,L]
RewriteRule ^my_pets$                 public/user/my_pets.php [QSA,L]
RewriteRule ^add_pet$                 public/user/add_pet.php [QSA,L]
RewriteRule ^edit_pet$                public/user/edit_pet.php [QSA,L]
RewriteRule ^delete_pet$              public/user/delete_pet.php [QSA,L]

# ── Reviews ─────────────────────────────────────────────────
RewriteRule ^product_reviews$         public/reviews/product_reviews.php [QSA,L]
RewriteRule ^write_review$            public/reviews/write_review.php [QSA,L]

# ── Contact ─────────────────────────────────────────────────
RewriteRule ^contact$                 public/orders/contact.php [QSA,L]
RewriteRule ^contact_process$         public/orders/contact_process.php [QSA,L]

# ── Static pages ────────────────────────────────────────────
RewriteRule ^about$                   public/pages/about.php [QSA,L]
RewriteRule ^faq$                     public/pages/faq.php [QSA,L]
RewriteRule ^privacy$                 public/pages/privacy.php [QSA,L]
RewriteRule ^terms$                   public/pages/terms.php [QSA,L]
RewriteRule ^sitemap$                 public/pages/sitemap.php [QSA,L]

# ── 404 fallback ────────────────────────────────────────────
RewriteRule ^404$                     public/errors/404.php [QSA,L]

# API routes
RewriteRule ^api/([a-zA-Z0-9_-]+)$ backend/api/$1.php [QSA,L]